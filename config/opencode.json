{
  "$schema": "https://opencode.ai/config.json",
  "agent": {
    "build": {
      "disable": true
    },
    "explore": {
      "disable": true
    },
    "general": {
      "disable": true
    },
    "plan": {
      "disable": true
    },
    "xhigh-skill": {
      "color": "primary",
      "description": "XHigh qwen3.5 default coding agent",
      "mode": "primary",
      "model": "ollama/qwen3.5"
    }
  },
  "default_agent": "xhigh-skill",
  "enabled_providers": [
    "ollama"
  ],
  "model": "ollama/qwen3.5",
  "permission": {
    "websearch": "allow"
  },
  "provider": {
    "ollama": {
      "models": {
        "qwen3.5": {
          "_launch": true,
          "name": "qwen3.5"
        }
      },
      "name": "xhigh",
      "npm": "@ai-sdk/openai-compatible",
      "options": {
        "baseURL": "http://127.0.0.1:11434/v1"
      },
      "whitelist": [
        "qwen3.5"
      ]
    }
  },
  "small_model": "ollama/qwen3.5"
}
